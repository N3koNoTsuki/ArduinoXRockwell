</DataType>
<DataType Name="MSG_ReadResponse" Family="NoFamily" Class="User">
<Members>
<Member Name="FromAddr" DataType="MSG_SockAddr" Dimension="0" Radix="NullType" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[A user-defined structure that can contain the address of the device that sends UDP data. This structure is populated
from the end device.
For TCP or UDP with OpenConnection, this structure is not used and contains all zeros. The TCP connection conveys all
remote address information]]>
</Description>
</Member>
<Member Name="BufLen" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Contains the number of bytes of data received]]>
</Description>
</Member>
<Member Name="Buf" DataType="USINT" Dimension="3984" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Contains the data.
This number must be large enough to contain the maximum amount of data expected. For a standard connection, the
maximum is SINT[484]. For a large connection, the maximum is SINT [3984].]]>
</Description>
</Member>
</Members>
<Dependencies>
<Dependency Type="DataType" Name="MSG_SockAddr"/>
</Dependencies>
</DataType>
<DataType Name="MSG_SockAddr" Family="NoFamily" Class="User">
<Members>
<Member Name="Family" DataType="INT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Adress Family Must be 2]]>
</Description>
</Member>
<Member Name="Port" DataType="INT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Port Number - If random needed use 0]]>
</Description>
</Member>
<Member Name="Addr" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[IP Address - Each Byte are separated for xxx.xxx.xxx.xxx]]>
</Description>
</Member>
</Members>
</DataType>
<DataType Name="MSG_WriteParameters" Family="NoFamily" Class="User">
<Members>
<Member Name="TimeOut" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[TimeOut in milliseconds]]>
</Description>
</Member>
<Member Name="ToAddr" DataType="MSG_SockAddr" Dimension="0" Radix="NullType" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Structure that contains the address to which to write UDP data.
For TCP or UDP with OpenConnection, this structure is not used and contains all zeros. The TCP connection conveys all
required remote address information.]]>
</Description>
</Member>
<Member Name="BufLen" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Specify the number of bytes of data to write]]>
</Description>
</Member>
<Member Name="Buf" DataType="SINT" Dimension="3972" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Contains the data.
This number must be large enough to contain the maximum amount of data expected. For a standard connection, the
maximum is SINT[472]. For a large connection, the maximum is SINT [3972].]]>
</Description>
</Member>
</Members>
