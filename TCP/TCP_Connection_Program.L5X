<Routines>
<Routine Name="Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[JSR(_01_00_Connection_Management,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Check lenght for Array
]]>
</Comment>
<Text>
<![CDATA[[LES(OPTP_Data_RCV.Lenght,0) MOV(0,OPTP_Data_RCV.Lenght) ,GRT(OPTP_Data_RCV.Lenght,4999) MOV(4999,OPTP_Data_RCV.Lenght) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Copy Received Buffer to OPTP Tag

]]>
</Comment>
<Text>
<![CDATA[NEQ(Destination_Element_Read_Request.BufLen,0)XIC(MSG_Read_Request.DN)ONS(ONS[3])COP(Destination_Element_Read_Request.Buf[0],OPTP_Data_RCV.Buffer[OPTP_Data_RCV.Lenght],Destination_Element_Read_Request.BufLen)ADD(OPTP_Data_RCV.Lenght,Destination_Element_Read_Request.BufLen,OPTP_Data_RCV.Lenght)MOV(0,Destination_Element_Read_Request.BufLen)OTL(OPTP_RECV_CONTROL.New_TCP_Data);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Copy Buffer Send Snapshot to OPTP

]]>
</Comment>
<Text>
<![CDATA[MOV(OPTP_Data_SND.Lenght,Source_Element_Write_Request.BufLen)COP(OPTP_Data_SND.Buffer[0],Source_Element_Write_Request.Buf[0],3972);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[////////////////////    TEST     /////////////////]]>
</Comment>
<Text>
<![CDATA[XIC(GENERAL.BLINK.Edge_5s)OTE(Write_Request);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="_01_00_Connection_Management" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[
CREATE SOCKET 
(Initialize Communication Adapter)

In varaible Source_Element_Create_Socket :
SpecIFy 
- communication type : TCP
Port : xxx
Address (for source) : 0 for Auto
 
Return an instance number for all the others requests (Instance OPTP)


]]>
</Comment>
<Text>
<![CDATA[XIO(MSG_Create_Socket.DN)XIC(GENERAL.BLINK.Edge_1s)MSG(MSG_Create_Socket);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[
OPEN CONNECTION
(for TCP Client to OPTP)

Write Instance Number : With the value of the Create Socket

In variable Source_Element_Open_Connection : 
SpecIFy
Timeout : 3000 ms
IP / port Dest : String "120.141.18.34?port=10001"  ---> Replace the IP & Port by the TCP server


]]>
</Comment>
<Text>
<![CDATA[XIC(MSG_Create_Socket.DN)ONS(ONS[0])MOV(Instance_OPTP,MSG_Open_Connection.Instance)MSG(MSG_Open_Connection);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[
READ REQUEST
 
 When Read is ON, the value is set in the Destination_Element_Read_Request Variable :

Destination_Element_Read_Request.FromAddr : Not Used
Destination_Element_Read_Request.BufLen : Lenght of the data
Destination_Element_Read_Request.Buf : Data Buffer
 
 

]]>
</Comment>
<Text>
<![CDATA[XIC(MSG_Create_Socket.DN)XIC(MSG_Open_Connection.DN)XIC(Date_Time.MicroSecond.14)XIC(GENERAL.BLINK.Edge_100ms)ONS(ONS[1])MOV(Instance_OPTP,MSG_Read_Request.Instance)MSG(MSG_Read_Request);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[
WRITE REQUEST
 
 Source_Element_Write_Request.TimeOut : 3000 ms
Source_Element_Write_Request.ToAddr : Not Used
Source_Element_Write_Request.BufLen : Lenght of the Data to Send
Source_Element_Write_Request.Buf : Data to send


]]>
</Comment>
<Text>
<![CDATA[XIC(MSG_Create_Socket.DN)XIC(MSG_Open_Connection.DN)XIC(Write_Request)ONS(ONS[2])MOV(Instance_OPTP,MSG_Write_Request.Instance)CPT(MSG_Write_Request.REQ_LEN,16+Source_Element_Write_Request.BufLen)MSG(MSG_Write_Request);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[
DELETE SOCKET
(IF Error)
 


 
]]>
</Comment>
<Text>
<![CDATA[[XIC(MSG_Create_Socket.ER) ,XIC(MSG_Open_Connection.ER) ,XIC(MSG_Read_Request.ER) ,XIC(MSG_Write_Request.ER) ]XIC(GENERAL.BLINK.Edge_1s)[MOV(Instance_OPTP,MSG_Delete_Socket.Instance) MSG(MSG_Delete_Socket) ,OTU(MSG_Open_Connection.ER) OTU(MSG_Read_Request.ER) OTU(MSG_Open_Connection.DN) OTU(MSG_Create_Socket.DN) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[
DELETE ALL SOCKET

On Startup
 
]]>
</Comment>
<Text>
<![CDATA[[XIC(s:fs) ,XIC(test_mes.3) ]MSG(MSG_Delete_All_Socket);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
</Programs>
</Controller>
</RSLogix5000Content>
